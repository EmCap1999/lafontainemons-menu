{
	"name": "lafontainemons-menu",
	"version": "1.2.1",
	"description": "La Fontaine Mons - Restaurant menu application",
	"type": "module",
	"packageManager": "yarn@4.12.0",
	"scripts": {
		"dev": "docker compose up -d && turbo dev --ui tui",
		"dev:frontend": "yarn workspace frontend dev",
		"dev:backend": "yarn workspace @lafontaine/backend dev",
		"dev:stop": "docker compose down",
		"build": "turbo build",
		"lint": "biome check .",
		"lint:fix": "biome check --write --unsafe .",
		"typecheck:all": "turbo typecheck"
	},
	"workspaces": [
		"backend",
		"frontend",
		"database"
	],
	"author": {
		"name": "Emmanuel Caputo",
		"email": "caputoemmanuel1999@gmail.com"
	},
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^26.1.0",
		"dotenv": "^17.2.2",
		"tsx": "^4.23.0",
		"turbo": "^2.9.16"
	},
	"dependencies": {
		"esbuild": "^0.28.1"
	}
}
