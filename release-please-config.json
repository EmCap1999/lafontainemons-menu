{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"group-pull-request-title-pattern": "chore: release ${version}",
	"include-component-in-tag": false,
	"changelog-sections": [
		{
			"type": "feat",
			"section": "Features",
			"hidden": false
		},
		{
			"type": "fix",
			"section": "Bug Fixes",
			"hidden": false
		},
		{
			"type": "chore",
			"section": "Miscellaneous Chores",
			"hidden": true
		},
		{
			"type": "revert",
			"section": "Reverts",
			"hidden": false
		},
		{
			"type": "docs",
			"section": "Documentation",
			"hidden": false
		},
		{
			"type": "perf",
			"section": "Performance improvement",
			"hidden": false
		},
		{
			"type": "refactor",
			"section": "Code Refactoring",
			"hidden": false
		},
		{
			"type": "ci",
			"section": "Continuous Integration",
			"hidden": false
		},
		{
			"type": "build",
			"section": "Build Tools",
			"hidden": false
		},
		{
			"type": "deps",
			"section": "Dependencies",
			"hidden": false
		}
	],
	"packages": {
		".": {
			"component": "lafontainemons-menu",
			"release-type": "node"
		}
	}
}
